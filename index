<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home | DevGenius Portfolio</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header>
        <div class="container">
            <div class="logo">DevGenius</div>
            <nav>
                <ul>
                    <li><a href="index.html">Home</a></li>
                    <li><a href="about.html">About</a></li>
                    <li><a href="gallery.html">Gallery</a></li>
                    <li><a href="contact.html">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        <section class="hero-slider">
            <div class="slides">
                <div class="slide">
                    <img src="images/hero1.jpg" alt="Slide 1">
                    <div class="hero-text">
                        <h1>Welcome to My AI-Powered Site</h1>
                        <p>Building the future with clean code.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="about-preview container">
            <h2>About Me</h2>
            <div class="flex-row">
                <p>I am a creator focused on modern web design and development.</p>
                <img src="images/about-preview.jpg" alt="About Me">
            </div>
        </section>

        <section class="services container">
            <h2>What I Offer</h2>
            <div class="card-grid">
                <div class="card">
                    <h3>Design</h3>
                    <p>Clean and modern layouts.</p>
                </div>
                <div class="card">
                    <h3>Code</h3>
                    <p>Standardized HTML and CSS.</p>
                </div>
                <div class="card">
                    <h3>Launch</h3>
                    <p>Ready for the live web.</p>
                </div>
            </div>
        </section>

        <section class="gallery-preview container">
            <h2>Recent Work</h2>
            <div class="preview-grid">
                <img src="images/1.jpg" alt="Work 1">
                <img src="images/2.jpg" alt="Work 2">
                <img src="images/3.jpg" alt="Work 3">
                <img src="images/4.jpg" alt="Work 4">
                <img src="images/5.jpg" alt="Work 5">
                <img src="images/6.jpg" alt="Work 6">
            </div>
        </section>
    </main>

    <footer>
        <div class="container">
            <p>&copy; 2026 SweatHater | Built for Portfolio Project</p>
        </div>
    </footer>

</body>
</html>
